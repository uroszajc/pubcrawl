---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Crawl Routes" description="Curated pub crawl routes across Perth — Northbridge, Subiaco, Fremantle, Mounts Bay and more.">
  <section class="page-header">
    <h1>Crawl Routes</h1>
    <p>Pre-planned routes so you don't waste a single hour figuring out where to go next.</p>
  </section>

  <section class="routes-list">

    <div class="route-full" id="northbridge">
      <div class="route-header">
        <div>
          <span class="route-area">Northbridge → CBD</span>
          <h2>Northbridge Loop</h2>
          <p class="route-meta">4 bars · ~2.5hrs walking · Easy difficulty</p>
        </div>
        <div class="route-stops">4</div>
      </div>
      <div class="stops">
        <div class="stop">
          <div class="stop-num">1</div>
          <div class="stop-info">
            <h3>Northbridge Brewing Co.</h3>
            <p>150x, 180x Beer</p>
            <p class="stop-address">📍 65 Aberdeen St, Northbridge</p>
          </div>
          <div class="stop-time">Walk 6min</div>
        </div>
        <div class="stop">
          <div class="stop-num">2</div>
          <div class="stop-info">
            <h3>The Gramercy</h3>
            <p>Live music every night · Free entry before 9pm</p>
            <p class="stop-address">📍 206 William St, Northbridge</p>
          </div>
          <div class="stop-time">Walk 8min</div>
        </div>
        <div class="stop">
          <div class="stop-num">3</div>
          <div class="stop-info">
            <h3>Frisco Pub</h3>
            <p>Craft tap selection, great courtyard</p>
            <p class="stop-address">📍 161 Brisbane St, Northbridge</p>
          </div>
          <div class="stop-time">Walk 7min</div>
        </div>
        <div class="stop">
          <div class="stop-num">4</div>
          <div class="stop-info">
            <h3>The Shoe</h3>
            <p>Late-night energy, solid drinks list</p>
            <p class="stop-address">📍 207 William St, Northbridge</p>
          </div>
          <div class="stop-time">— End</div>
        </div>
      </div>
      <a href="/bars" class="btn">View Full Bar Directory →</a>
    </div>

    <div class="route-full" id="fremantle">
      <div class="route-header">
        <div>
          <span class="route-area">Fremantle</span>
          <h2>Freo Crawl</h2>
          <p class="route-meta">6 bars · ~4hrs · Day or night</p>
        </div>
        <div class="route-stops">6</div>
      </div>
      <div class="stops">
        <div class="stop"><div class="stop-num">1</div><div class="stop-info"><h3>The Dock</h3><p>Waterfront craft beers, big outdoor deck</p><p class="stop-address">📍 1/2 Riverside Dr, Fremantle</p></div><div class="stop-time">Walk 10min</div></div>
        <div class="stop"><div class="stop-num">2</div><div class="stop-info"><h3>Little Creatures</h3><p>Perth institution · rotating taps · warehouse space</p><p class="stop-address">📍 9/9–11 Mews Rd, Fremantle</p></div><div class="stop-time">Walk 4min</div></div>
        <div class="stop"><div class="stop-num">3</div><div class="stop-info"><h3>Norfolk Hotel</h3><p>Classic pub, cold pints, good rooftop</p><p class="stop-address">📍 47 South St, Fremantle</p></div><div class="stop-time">Walk 11min</div></div>
        <div class="stop"><div class="stop-num">4</div><div class="stop-info"><h3>The National Hotel</h3><p>Live music Fridays · excellent cocktail list</p><p class="stop-address">📍 51 High St, Fremantle</p></div><div class="stop-time">Walk 8min</div></div>
        <div class="stop"><div class="stop-num">5</div><div class="stop-info"><h3>Beermotion</h3><p>Specialty craft · cans + draughts</p><p class="stop-address">📍 42 Pakenham St, Fremantle</p></div><div class="stop-time">Walk 6min</div></div>
        <div class="stop"><div class="stop-num">6</div><div class="stop-info"><h3>Gypsy Temptation</h3><p>Espresso bar by day, cocktail bar by night</p><p class="stop-address">📍 76 Pakenham St, Fremantle</p></div><div class="stop-time">— End</div></div>
      </div>
      <a href="/bars" class="btn">View Full Bar Directory →</a>
    </div>

    <div class="route-full" id="subiaco">
      <div class="route-header">
        <div>
          <span class="route-area">Subiaco</span>
          <h2>Subi After Dark</h2>
          <p class="route-meta">5 bars · ~3hrs · Thursday–Saturday best</p>
        </div>
        <div class="route-stops">5</div>
      </div>
      <div class="stops">
        <div class="stop"><div class="stop-num">1</div><div class="stop-info"><h3>Palace Hotel</h3><p>Heritage pub, cold beer garden, live music</p><p class="stop-address">📍 445 Great Hwy, Subiaco</p></div><div class="stop-time">Walk 5min</div></div>
        <div class="stop"><div class="stop-num">2</div><div class="stop-info"><h3>Rocket Roasters</h3><p>Craft beer + coffee · quirky space</p><p class="stop-address">📍 233a Rokeby Rd, Subiaco</p></div><div class="stop-time">Walk 7min</div></div>
        <div class="stop"><div class="stop-num">3</div><div class="stop-info"><h3>Mundaryn's</h3><p>Local favourite · 18 taps · solid food</p><p class="stop-address">📍 285 Rokeby Rd, Subiaco</p></div><div class="stop-time">Walk 9min</div></div>
        <div class="stop"><div class="stop-num">4</div><div class="stop-info"><h3>The Shelf</h3><p>Cocktails, natural wines · intimate vibe</p><p class="stop-address">📍 2/297 Rokeby Rd, Subiaco</p></div><div class="stop-time">Walk 5min</div></div>
        <div class="stop"><div class="stop-num">5</div><div class="stop-info"><h3>Evilcy Brewing</h3><p>Local microbrewery · tasters available</p><p class="stop-address">📍 11C Aberdeen St, Subiaco</p></div><div class="stop-time">— End</div></div>
      </div>
      <a href="/bars" class="btn">View Full Bar Directory →</a>
    </div>

    <div class="route-full" id="mounts">
      <div class="route-header">
        <div>
          <span class="route-area">Mounts Bay</span>
          <h2>Mounts Bayound</h2>
          <p class="route-meta">4 bars · ~2hrs · Waterfront views</p>
        </div>
        <div class="route-stops">4</div>
      </div>
      <div class="stops">
        <div class="stop"><div class="stop-num">1</div><div class="stop-info"><h3>The湾</h3><p>Asian fusion + cocktails · Swan River views</p><p class="stop-address">📍 2 The Boardwalk, Mounts Bay</p></div><div class="stop-time">Walk 12min</div></div>
        <div class="stop"><div class="stop-num">2</div><div class="stop-info"><h3>Helly's</h3><p>Perth institution · cheap pints, late bar</p><p class="stop-address">📍 44 Mews Rd, Perth</p></div><div class="stop-time">Walk 5min</div></div>
        <div class="stop"><div class="stop-num">3</div><div class="stop-info"><h3>Groucho's</h3><p>Harbour views · live music Fri/Sat</p><p class="stop-address">📍 44 Mews Rd, Perth</p></div><div class="stop-time">Walk 3min</div></div>
        <div class="stop"><div class="stop-num">4</div><div class="stop-info"><h3>Groucho's Bar</h3><p>River-facing terrace · cocktails and wine</p><p class="stop-address">📍 44 Mews Rd, Perth</p></div><div class="stop-time">— End</div></div>
      </div>
      <a href="/bars" class="btn">View Full Bar Directory →</a>
    </div>

  </section>
</Layout>

<style>
.page-header { background: var(--surface); padding: 4rem 2rem 3rem; text-align: center; }
.page-header h1 { font-size: 3.5rem; color: white; margin-bottom: 0.5rem; }
.page-header p { color: var(--text-dim); }
.routes-list { max-width: 900px; margin: 0 auto; padding: 3rem 2rem; display: flex; flex-direction: column; gap: 3rem; }
.route-full { background: var(--card); border-radius: 12px; padding: 2.5rem; border: 1px solid var(--border); }
.route-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 1.5rem; }
.route-header h2 { font-size: 2rem; color: white; margin-bottom: 0.3rem; }
.route-area { font-size: 0.75rem; color: var(--neon-cyan); text-transform: uppercase; letter-spacing: 0.15em; display: block; margin-bottom: 0.3rem; }
.route-meta { font-size: 0.85rem; color: var(--text-dim); }
.route-stops { font-family: 'Bebas Neue', sans-serif; font-size: 3rem; color: var(--neon-pink); line-height: 1; }
.stops { display: flex; flex-direction: column; gap: 0.8rem; margin-bottom: 2rem; }
.stop { display: flex; align-items: center; gap: 1.2rem; padding: 0.8rem 0; border-bottom: 1px solid var(--border); }
.stop:last-child { border-bottom: none; }
.stop-num { width: 32px; height: 32px; background: var(--neon-pink); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.85rem; color: white; flex-shrink: 0; }
.stop-info h3 { font-size: 1.05rem; color: white; margin-bottom: 0.1rem; font-family: 'Bebas Neue', sans-serif; text-transform: uppercase; letter-spacing: 0.05em; }
.stop-info p { font-size: 0.82rem; color: var(--text-dim); }
.stop-address { font-size: 0.75rem !important; color: var(--neon-cyan) !important; }
.stop-time { margin-left: auto; font-size: 0.78rem; color: var(--text-dim); white-space: nowrap; }
</style>