---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <section class="hero">
    <div class="hero-content">
      <p class="tagline">Perth's Premier Pub Crawl Guide</p>
      <h1>Find Your<br/>Next Stop</h1>
      <p class="sub">Curated crawl routes and Perth's best bars — all in one place. Plan your night, pick your stops, go.</p>
      <div class="hero-cta">
        <a href="/routes" class="btn">Explore Routes</a>
        <a href="/bars" class="btn btn-outline">Browse Bars</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>🔥 Popular Routes</h2>
      <div class="route-grid">
        <a href="/routes#northbridge" class="route-card">
          <div class="route-badge">4 Bars</div>
          <h3>Northbridge Loop</h3>
          <p>4 stops · ~2.5hrs · Free to walk</p>
          <span class="route-area">Northbridge → CBD</span>
        </a>
        <a href="/routes#subiaco" class="route-card">
          <div class="route-badge">5 Bars</div>
          <h3>Subi After Dark</h3>
          <p>5 stops · ~3hrs · Trending</p>
          <span class="route-area">Subiaco</span>
        </a>
        <a href="/routes#fremantle" class="route-card">
          <div class="route-badge">6 Bars</div>
          <h3>Freo Crawl</h3>
          <p>6 stops · ~4hrs · Day trip worthy</p>
          <span class="route-area">Fremantle</span>
        </a>
        <a href="/routes#mounts" class="route-card">
          <div class="route-badge">4 Bars</div>
          <h3>Mounts Bayound</h3>
          <p>4 stops · ~2hrs · Waterfront views</p>
          <span class="route-area">Mounts Bay</span>
        </a>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>🍸 Trending This Week</h2>
      <div class="bar-grid">
        <div class="bar-card">
          <div class="bar-icon">🍹</div>
          <h3>Aviation Brewery</h3>
          <p class="bar-area">Highgate</p>
          <p>Craft beers, sourdough pizzas, dog-friendly. Best IPA in Perth according to locals.</p>
          <div class="bar-tags">
            <span class="tag tag-beer">Craft Beer</span>
            <span class="tag tag-free-entry">Free Entry</span>
          </div>
        </div>
        <div class="bar-card">
          <div class="bar-icon">🍷</div>
          <h3>The Vue</h3>
          <p class="bar-area">East Perth</p>
          <p>Rooftop bar with city skyline views. Cocktails are a standout — try the Espresso Martini.</p>
          <div class="bar-tags">
            <span class="tag tag-rooftop">Rooftop</span>
            <span class="tag tag-cocktail">Cocktails</span>
          </div>
        </div>
        <div class="bar-card">
          <div class="bar-icon">🎸</div>
          <h3>The Gramercy</h3>
          <p class="bar-area">Northbridge</p>
          <p>Live music every night. Jazz on Wednesdays, indie bands on weekends. No cover charge.</p>
          <div class="bar-tags">
            <span class="tag tag-live">Live Music</span>
            <span class="tag tag-free-entry">Free Entry</span>
          </div>
        </div>
        <div class="bar-card">
          <div class="bar-icon">🍺</div>
          <h3>Last Joint</h3>
          <p class="bar-area">Leederville</p>
          <p>Neighbourhood staple with 20 rotating taps and goodpub grub. Always a solid vibe.</p>
          <div class="bar-tags">
            <span class="tag tag-beer">20 Taps</span>
          </div>
        </div>
      </div>
      <div style="text-align:center; margin-top:2rem;">
        <a href="/bars" class="btn btn-outline">See All Bars →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container how-it-works">
      <h2>How It Works</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <h3>Pick a Route</h3>
          <p>Choose from our curated pub crawl routes — each one designed to hit the best spots with zero filler.</p>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <h3>Save Your Stops</h3>
          <p>Browse the bar directory and add your own picks. Every bar has addresses, map links and insider tips.</p>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <h3>Start Crawling</h3>
          <p>Hit the first stop, work your way through. We give you walking times, estimated costs, and pro tips.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
.section { padding: 5rem 0; }
.section.alt { background: var(--surface); }
.container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
h2 { font-size: 2.5rem; text-align: center; margin-bottom: 3rem; color: white; }
.container h2 { margin-bottom: 3rem; }

.route-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 1.5rem; }
.route-card {
  background: var(--card); border-radius: 10px; padding: 2rem; display: block;
  border: 1px solid var(--border); transition: transform 0.2s, border-color 0.2s;
  position: relative; overflow: hidden;
}
.route-card:hover { transform: translateY(-4px); border-color: var(--neon-pink); color: var(--neon-pink); }
.route-card h3 { font-size: 1.5rem; color: white; margin-bottom: 0.4rem; }
.route-card p { font-size: 0.88rem; color: var(--text-dim); margin-bottom: 0.8rem; }
.route-badge { position: absolute; top: 1rem; right: 1rem; background: var(--neon-pink); color: white; font-size: 0.7rem; font-weight: 700; padding: 0.2rem 0.6rem; border-radius: 3px; text-transform: uppercase; }
.route-area { display: block; font-size: 0.78rem; color: var(--neon-cyan); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 0.5rem; }

.bar-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
.bar-card { background: var(--bg); border-radius: 10px; padding: 1.8rem; border: 1px solid var(--border); }
.bar-icon { font-size: 2.2rem; margin-bottom: 0.8rem; }
.bar-card h3 { font-size: 1.25rem; color: white; margin-bottom: 0.2rem; }
.bar-area { font-size: 0.8rem; color: var(--neon-cyan); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.7rem; display: block; }
.bar-card p { font-size: 0.88rem; color: var(--text-dim); margin-bottom: 1rem; }
.bar-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }

.how-it-works h2 { margin-bottom: 3rem; }
.steps { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; text-align: center; }
.step { padding: 1.5rem; }
.step-num { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; color: var(--neon-pink); opacity: 0.7; margin-bottom: 0.5rem; }
.step h3 { font-size: 1.3rem; color: white; margin-bottom: 0.5rem; }
.step p { font-size: 0.88rem; color: var(--text-dim); }
</style>